# คัดลอกเป็น /etc/ddoc.env แล้วเติมค่าจริง (โดยเฉพาะ R2 ให้ใช้ "ชุดเดิมกับ Render"
# เพื่อให้เปิดเครื่องครั้งแรกแล้วระบบกู้ข้อมูลจาก R2 มาให้อัตโนมัติ)

# ผู้ดูแลระบบเริ่มต้น (จะถูกบังคับเปลี่ยนรหัสครั้งแรก)
DDOC_SUPERADMIN=admin
DDOC_SUPERADMIN_PW=เปลี่ยนรหัสนี้

# HTTPS: ตั้ง 1 เฉพาะเมื่อมีโดเมน + ใบรับรอง (nginx+certbot) แล้ว
# ถ้ายังเข้าด้วย IP ผ่าน http อยู่ ให้ตั้ง 0 ก่อน (ไม่งั้นคุกกี้ Secure จะล็อกอินไม่ได้)
DDOC_HTTPS=0

# สำรองขึ้นคลาวด์ (ใช้ค่าเดียวกับที่ตั้งบน Render -> ครั้งแรกจะกู้ข้อมูลกลับมา)
DDOC_AUTO_BACKUP=1
DDOC_BACKUP_INTERVAL_MIN=10
BACKUP_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
BACKUP_S3_BUCKET=ddoc-backups
BACKUP_S3_KEY_ID=<access key id>
BACKUP_S3_SECRET=<secret>
BACKUP_S3_REGION=auto
